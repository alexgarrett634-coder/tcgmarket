# Database — Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Auth — generate a random 32+ char string
SECRET_KEY=change-me-to-a-random-32-character-string

# Frontend URL — your Vercel URL after deployment
FRONTEND_URL=https://your-app.vercel.app

# Optional — leave blank if not using
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
